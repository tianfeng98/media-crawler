{
  "name": "media-crawler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "chromium-install": "pnpm dlx playwright install chromium-headless-shell --with-deps --no-shell",
    "ffmpeg-install": "node -e \"require('@ffmpeg-installer/ffmpeg')\"",
    "before-start": "pnpm run ffmpeg-install && pnpm run chromium-install",
    "build": "next build --turbopack",
    "start": "next start",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.18",
    "file-saver": "^2.0.5",
    "fluent-ffmpeg": "^2.1.3",
    "keyv": "^5.5.2",
    "lucide-react": "^0.544.0",
    "m3u-parser-generator": "^5.0.2",
    "next": "15.5.3",
    "next-themes": "^0.4.6",
    "p-limit": "^7.1.1",
    "path-browserify": "^1.0.1",
    "playwright": "^1.55.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rimraf": "^6.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/keyv": "^4.2.0",
    "@types/node": "^20",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-emoji": "1.3.2-canary.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  },
  "packageManager": "pnpm@8.15.5+sha1.a58c038faac410c947dbdb93eb30994037d0fce2"
}
