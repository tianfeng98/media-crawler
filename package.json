{
  "name": "media-crawler",
  "version": "0.1.7",
  "description": "基于 Next.js 的智能视频下载器，支持从网页中提取、下载和转换视频文件",
  "author": "linktodream@163.com",
  "license": "MIT",
  "keywords": [
    "video-downloader",
    "media-crawler",
    "next.js",
    "playwright",
    "hls",
    "video-processing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tianfeng98/media-crawler.git"
  },
  "homepage": "https://github.com/tianfeng98/media-crawler#readme",
  "bugs": {
    "url": "https://github.com/tianfeng98/media-crawler/issues"
  },
  "scripts": {
    "dev": "next dev",
    "chromium-install": "pnpm dlx playwright install chromium-headless-shell --with-deps --no-shell",
    "ffmpeg-install": "node -e \"require('@ffmpeg-installer/ffmpeg')\"",
    "before-start": "pnpm run ffmpeg-install && pnpm run chromium-install",
    "build": "next build --turbopack",
    "start": "next start",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@keyv/redis": "^5.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "ahooks": "^3.9.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "file-saver": "^2.0.5",
    "fluent-ffmpeg": "^2.1.3",
    "jsonrepair": "^3.13.2",
    "keyv": "^5.6.0",
    "lucide-react": "^0.563.0",
    "m3u-parser-generator": "^5.0.2",
    "markdown-it": "^14.1.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.18.0",
    "p-limit": "^7.3.0",
    "path-browserify": "^1.0.1",
    "playwright": "~1.56.0",
    "radashi": "^12.7.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rimraf": "^6.1.2",
    "tailwind-merge": "^3.4.0",
    "task-runner-plus": "^0.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/file-saver": "^2.0.7",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/keyv": "^4.2.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.11",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.1",
    "cz-emoji": "1.3.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@8.15.5+sha1.a58c038faac410c947dbdb93eb30994037d0fce2"
}
